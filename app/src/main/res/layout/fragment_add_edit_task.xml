<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="36dp">

        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Task"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Task Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TASK TITLE"
            android:textColor="@color/blue_accent"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <EditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Read Chapter 5"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="18dp"
            android:inputType="text" />

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCRIPTION"
            android:textColor="@color/blue_accent"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <EditText
            android:id="@+id/etTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Optional details..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="14dp"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="18dp" />

        <!-- Priority -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRIORITY"
            android:textColor="@color/blue_accent"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <Spinner
            android:id="@+id/spinnerPriority"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:popupBackground="@color/bg_mid"
            android:layout_marginBottom="18dp" />

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY"
            android:textColor="@color/blue_accent"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:popupBackground="@color/bg_mid"
            android:layout_marginBottom="18dp" />

        <!-- Due Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DUE DATE"
            android:textColor="@color/blue_accent"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅  Tap to select due date"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="18dp" />

        <!-- Estimated Pomodoros -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESTIMATED POMODOROS 🍅"
            android:textColor="@color/blue_accent"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:layout_marginBottom="7dp" />

        <EditText
            android:id="@+id/etEstimatedPomodoros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="14dp"
            android:inputType="number"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="30dp" />

        <Button
            android:id="@+id/btnSaveTask"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Task"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_gradient_card"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>