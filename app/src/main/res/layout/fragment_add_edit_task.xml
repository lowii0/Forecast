<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Task"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="22dp" />

        <!-- Task Title input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TASK TITLE"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Read Chapter 5"
            android:textColorHint="#555F6E"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="16dp"
            android:inputType="text" />

        <!-- Description input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DESCRIPTION"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Optional details..."
            android:textColorHint="#555F6E"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="14dp"
            android:minLines="3"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="16dp" />

        <!-- Priority spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRIORITY"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerPriority"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:popupBackground="#1B3A6B"
            android:layout_marginBottom="16dp" />

        <!-- Category spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CATEGORY"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_input_field"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:popupBackground="#1B3A6B"
            android:layout_marginBottom="16dp" />

        <!-- Due date picker -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DUE DATE"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅  Tap to select due date"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:padding="14dp"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="16dp" />

        <!-- Estimated Pomodoros -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ESTIMATED POMODOROS 🍅"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etEstimatedPomodoros"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1"
            android:textColorHint="#555F6E"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:padding="14dp"
            android:inputType="number"
            android:background="@drawable/bg_input_field"
            android:layout_marginBottom="28dp" />

        <!-- Save button -->
        <Button
            android:id="@+id/btnSaveTask"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Task"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_gradient_card"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
