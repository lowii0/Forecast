<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_glass_card"
    android:padding="13dp">

    <!-- Set by TaskAdapter → task.isCompleted() -->
    <CheckBox
        android:id="@+id/checkBoxCompleted"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:buttonTint="#16A34A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Set by TaskAdapter → task.getTitle() -->
    <TextView
        android:id="@+id/tvTaskTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintStart_toEndOf="@id/checkBoxCompleted"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteTask"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Set by TaskAdapter → task.getDescription() — GONE when empty -->
    <TextView
        android:id="@+id/tvTaskDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:visibility="gone"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/checkBoxCompleted"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteTask"
        app:layout_constraintTop_toBottomOf="@id/tvTaskTitle" />

    <!-- Category • Priority badge row -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toEndOf="@id/checkBoxCompleted"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteTask"
        app:layout_constraintTop_toBottomOf="@id/tvTaskDescription">

        <!-- Set by TaskAdapter → task.getCategory().name() -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#93C5FD"
            android:textSize="10sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" • "
            android:textColor="#94A3B8"
            android:textSize="10sp" />

        <!-- Set by TaskAdapter → task.getPriority().name()
             Background swapped in code based on priority level -->
        <TextView
            android:id="@+id/tvPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FCD34D"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/bg_priority_medium"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp" />

    </LinearLayout>

    <!-- Triggers TaskAdapter.OnTaskDeleteListener -->
    <ImageButton
        android:id="@+id/btnDeleteTask"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="#55FFFFFF"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
