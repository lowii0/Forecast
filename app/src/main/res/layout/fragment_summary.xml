<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="20dp"
            android:paddingBottom="14dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Forecast"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSummaryDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/layoutLoading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="@color/blue_accent" />

            <Button
                android:id="@+id/btnRefreshSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textColor="@color/blue_accent"
                android:textSize="20sp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- ── Hero weather card ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_gradient_card"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvConditionEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="64sp"
                    android:layout_marginEnd="18dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvConditionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductivityScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/gold_bright"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="0.9" />

                    <TextView
                        android:id="@+id/tvMotivationalMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#CCE8FFFF"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressScore"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/gold_bright"
                android:progressBackgroundTint="#33FFFFFF"
                android:layout_marginBottom="16dp" />

            <!-- Stats strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bg_stat_chip"
                    android:padding="10dp" android:layout_marginEnd="5dp">
                    <TextView android:id="@+id/tvCompletedTasks"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#FFFFFF"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tasks" android:textColor="#AAFFFFFF" android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bg_stat_chip"
                    android:padding="10dp" android:layout_marginEnd="5dp">
                    <TextView android:id="@+id/tvCompletedSessions"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#FFFFFF"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pomodoros" android:textColor="#AAFFFFFF" android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bg_stat_chip"
                    android:padding="10dp" android:layout_marginEnd="5dp">
                    <TextView android:id="@+id/tvFocusMinutes"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#FFFFFF"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Focus" android:textColor="#AAFFFFFF" android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bg_stat_chip"
                    android:padding="10dp">
                    <TextView android:id="@+id/tvTotalTasks"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="#FFFFFF"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Left" android:textColor="#AAFFFFFF" android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Weather scale ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="14dp"
            android:weightSum="4">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⛈" android:textSize="20sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Stormy" android:textColor="@color/text_primary" android:textSize="9sp"
                    android:textStyle="bold" android:layout_marginTop="4dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0–20%" android:textColor="@color/text_secondary" android:textSize="8sp"
                    android:layout_marginTop="2dp" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☁️" android:textSize="20sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cloudy" android:textColor="@color/text_primary" android:textSize="9sp"
                    android:textStyle="bold" android:layout_marginTop="4dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="41–60%" android:textColor="@color/text_secondary" android:textSize="8sp"
                    android:layout_marginTop="2dp" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⛅" android:textSize="20sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="P.Sunny" android:textColor="@color/text_primary" android:textSize="9sp"
                    android:textStyle="bold" android:layout_marginTop="4dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="61–80%" android:textColor="@color/text_secondary" android:textSize="8sp"
                    android:layout_marginTop="2dp" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="20sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sunny" android:textColor="@color/text_primary" android:textSize="9sp"
                    android:textStyle="bold" android:layout_marginTop="4dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="81–100%" android:textColor="@color/text_secondary" android:textSize="8sp"
                    android:layout_marginTop="2dp" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Score breakdown ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_glass_card"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score Breakdown"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/blue_main"
                    android:progressBackgroundTint="#1AFFFFFF" />

                <TextView
                    android:id="@+id/tvTaskRate"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Pomodoros"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/gold"
                    android:progressBackgroundTint="#1AFFFFFF" />

                <TextView
                    android:id="@+id/tvTotalSessions"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginStart="10dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>