<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="14dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Forecast"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <!-- Set by SummaryFragment → DateTimeUtils.formatDate(summary.getDate()) -->
                <TextView
                    android:id="@+id/tvSummaryDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Shown while ProductivityRepository is loading -->
            <ProgressBar
                android:id="@+id/layoutLoading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:visibility="gone"
                android:indeterminateTint="#93C5FD" />

            <!-- Calls SummaryViewModel.refresh() -->
            <Button
                android:id="@+id/btnRefreshSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textColor="#93C5FD"
                android:textSize="18sp"
                android:background="@android:color/transparent"
                android:padding="8dp" />
        </LinearLayout>

        <!-- ── Big weather hero card ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_gradient_card"
            android:padding="20dp">

            <!-- Top: emoji + condition + score -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <!-- Set by SummaryFragment → condition emoji switch -->
                <TextView
                    android:id="@+id/tvConditionEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="60sp"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Set by SummaryFragment → ProductivityCalculator.getConditionLabel() -->
                    <TextView
                        android:id="@+id/tvConditionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <!-- Set by SummaryFragment → scoreInt + "%" -->
                    <TextView
                        android:id="@+id/tvProductivityScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#F59E0B"
                        android:textSize="40sp"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="0.9" />

                    <!-- Set by SummaryFragment → ProductivityCalculator.getMotivationalMessage() -->
                    <TextView
                        android:id="@+id/tvMotivationalMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Set by SummaryFragment → progressScore.setProgress(scoreInt) -->
            <ProgressBar
                android:id="@+id/progressScore"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#F59E0B"
                android:progressBackgroundTint="#33FFFFFF"
                android:layout_marginBottom="14dp" />

            <!-- Stats strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp">

                    <!-- Set by SummaryFragment → summary.getCompletedTasks() -->
                    <TextView
                        android:id="@+id/tvCompletedTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tasks"
                        android:textColor="#70FFFFFF"
                        android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp">

                    <!-- Set by SummaryFragment → summary.getCompletedFocusSessions() -->
                    <TextView
                        android:id="@+id/tvCompletedSessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pomodoros"
                        android:textColor="#70FFFFFF"
                        android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp">

                    <!-- Set by SummaryFragment → summary.getTotalFocusMinutes() + "m" -->
                    <TextView
                        android:id="@+id/tvFocusMinutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Focus"
                        android:textColor="#70FFFFFF"
                        android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp">

                    <!-- Set by SummaryFragment → totalTasks - completedTasks -->
                    <TextView
                        android:id="@+id/tvTotalTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Left"
                        android:textColor="#70FFFFFF"
                        android:textSize="9.5sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- ── Weather scale ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginBottom="14dp"
            android:weightSum="4">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⛈" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Stormy" android:textColor="#FFFFFF" android:textSize="8.5sp"
                    android:textStyle="bold" android:layout_marginTop="3dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0–20%" android:textColor="#80FFFFFF" android:textSize="8sp"
                    android:layout_marginTop="1dp" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☁️" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cloudy" android:textColor="#FFFFFF" android:textSize="8.5sp"
                    android:textStyle="bold" android:layout_marginTop="3dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="41–60%" android:textColor="#80FFFFFF" android:textSize="8sp"
                    android:layout_marginTop="1dp" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive"
                android:layout_marginEnd="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⛅" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="P.Sunny" android:textColor="#FFFFFF" android:textSize="8.5sp"
                    android:textStyle="bold" android:layout_marginTop="3dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="61–80%" android:textColor="#80FFFFFF" android:textSize="8sp"
                    android:layout_marginTop="1dp" android:gravity="center" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:padding="10dp" android:background="@drawable/bg_weather_scale_inactive">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="☀️" android:textSize="18sp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sunny" android:textColor="#FFFFFF" android:textSize="8.5sp"
                    android:textStyle="bold" android:layout_marginTop="3dp" android:gravity="center" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="81–100%" android:textColor="#80FFFFFF" android:textSize="8sp"
                    android:layout_marginTop="1dp" android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── Score breakdown card ───────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Score Breakdown"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Task completion rate row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />

                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#2563EB"
                    android:progressBackgroundTint="#22FFFFFF" />

                <!-- Set by SummaryFragment → summary.getTaskCompletionRate() + "%" -->
                <TextView
                    android:id="@+id/tvTaskRate"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Session completion rate row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="Pomodoros"
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />

                <ProgressBar
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#F59E0B"
                    android:progressBackgroundTint="#22FFFFFF" />

                <!-- Set by SummaryFragment → summary.getSessionCompletionRate() + "%" -->
                <TextView
                    android:id="@+id/tvTotalSessions"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
