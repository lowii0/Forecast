<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView android:id="@+id/tvGreeting" android:textSize="20sp"/>
    <TextView android:id="@+id/tvHomeDate"/>

    <TextView
        android:id="@+id/tvIncompleteTaskCount"
        android:text="0 tasks remaining"/>

    <Button
        android:id="@+id/btnGoToTasks"
        android:text="View Tasks"/>

    <Button
        android:id="@+id/btnGoToTimer"
        android:text="Start Timer"/>

</LinearLayout>