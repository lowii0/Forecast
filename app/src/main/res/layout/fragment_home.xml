<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── Greeting header ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Set by HomeFragment → DateTimeUtils.formatDate(new Date()) -->
                <TextView
                    android:id="@+id/tvHomeDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#99BFDBFE"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <!-- Set by HomeFragment → DateTimeUtils.getGreeting() -->
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp" />
            </LinearLayout>

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="ME"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_avatar" />
        </LinearLayout>

        <!-- ── Score / Forecast card ───────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_gradient_card"
            android:padding="20dp">

            <!-- Top row: condition text + emoji -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TODAY'S FORECAST"
                        android:textColor="#88FFFFFF"
                        android:textSize="10sp"
                        android:letterSpacing="0.12" />

                    <!-- Set by SummaryViewModel → ProductivityCalculator.getConditionLabel() -->
                    <TextView
                        android:id="@+id/tvConditionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="25sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <!-- Set by SummaryViewModel → ProductivityCalculator.getMotivationalMessage() -->
                    <TextView
                        android:id="@+id/tvMotivationalMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Set by SummaryViewModel → condition emoji switch -->
                <TextView
                    android:id="@+id/tvConditionEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="50sp"
                    android:layout_gravity="center_vertical" />
            </LinearLayout>

            <!-- Score percentage row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="7dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Daily Productivity Score"
                    android:textColor="#80FFFFFF"
                    android:textSize="10.5sp" />

                <!-- Set by SummaryViewModel → summary.getProductivityScore() -->
                <TextView
                    android:id="@+id/tvProductivityScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#F59E0B"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Set by SummaryViewModel → progressScore.setProgress(score) -->
            <ProgressBar
                android:id="@+id/progressScore"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#F59E0B"
                android:progressBackgroundTint="#33FFFFFF" />

            <!-- Stats strip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp">

                    <!-- Set by SummaryViewModel → summary.getCompletedTasks() -->
                    <TextView
                        android:id="@+id/tvCompletedTasks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tasks Done"
                        android:textColor="#70FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp">

                    <!-- Set by SummaryViewModel → summary.getCompletedFocusSessions() -->
                    <TextView
                        android:id="@+id/tvCompletedSessions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pomodoros"
                        android:textColor="#70FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_chip"
                    android:padding="9dp">

                    <!-- Set by HomeFragment → incompleteTasks.size() -->
                    <TextView
                        android:id="@+id/tvIncompleteTaskCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remaining"
                        android:textColor="#70FFFFFF"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- ── Pomodoro mini widget ────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_glass_card"
            android:padding="13dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_ring_placeholder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focus Timer"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to open timer"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Navigates to TimerFragment -->
            <Button
                android:id="@+id/btnGoToTimer"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="▶"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:padding="0dp"
                android:background="@drawable/bg_blue_circle" />

        </LinearLayout>

        <!-- ── Today's Tasks section ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="20dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today's Tasks"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Navigates to TasksFragment -->
            <TextView
                android:id="@+id/btnGoToTasks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View all →"
                android:textColor="#93C5FD"
                android:textSize="11sp"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Populated by HomeFragment observing TasksViewModel.getIncompleteTasks() -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewHomeTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

        <!-- Shown when no tasks exist yet -->
        <TextView
            android:id="@+id/tvHomeEmptyTasks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="No tasks yet — tap View all to add some!"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp" />

    </LinearLayout>
</ScrollView>
