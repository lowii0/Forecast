<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="14dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Prioritizer"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Powered by Gemini API"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- AI badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦ AI"
                android:textColor="#F9A8D4"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_ai_badge"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />

        </LinearLayout>

        <!-- ── Analyze button ─────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:text="🤖  Analyze &amp; Prioritize My Tasks"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_ai_button"
            android:stateListAnimator="@null" />

        <!-- ── Gemini reasoning box ───────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutAiReasoning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_ai_reasoning"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  GEMINI'S REASONING"
                android:textColor="#C4B5FD"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAiReasoning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Based on your deadlines and priority levels, I suggest tackling high-stakes tasks first."
                android:textColor="#B0BFDB"
                android:textSize="11.5sp"
                android:lineSpacingMultiplier="1.5" />

        </LinearLayout>

        <!-- ── Ranked task list ───────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Suggested Order"
            android:textColor="#FFFFFF"
            android:textSize="13.5sp"
            android:textStyle="bold"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="10dp" />

        <LinearLayout
            android:id="@+id/layoutAiTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <!-- Placeholder rows shown before AI loads -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_glass_card"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="1"
                    android:textColor="#78350F"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_rank_gold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Review group presentation slides"
                        android:textColor="#FFFFFF"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due tomorrow · High priority"
                        android:textColor="#94A3B8"
                        android:textSize="10.5sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#55FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_glass_card"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="2"
                    android:textColor="#1E293B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/bg_rank_silver" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Complete Physics Problem Set"
                        android:textColor="#FFFFFF"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due Mar 12 · High priority"
                        android:textColor="#94A3B8"
                        android:textSize="10.5sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#55FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Loading indicator for AI -->
        <ProgressBar
            android:id="@+id/progressAi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:indeterminateTint="#C4B5FD"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
