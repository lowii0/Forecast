<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus Timer"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSessionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions today: 0"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Session dots -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View android:layout_width="9dp" android:layout_height="9dp"
                android:background="@drawable/bg_session_dot_empty"
                android:layout_marginEnd="7dp" />
            <View android:layout_width="9dp" android:layout_height="9dp"
                android:background="@drawable/bg_session_dot_empty"
                android:layout_marginEnd="7dp" />
            <View android:layout_width="9dp" android:layout_height="9dp"
                android:background="@drawable/bg_session_dot_active"
                android:layout_marginEnd="7dp" />
            <View android:layout_width="9dp" android:layout_height="9dp"
                android:background="@drawable/bg_session_dot_empty" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Ring timer ────────────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_timer_ring" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25:00"
                android:textColor="@color/text_primary"
                android:textSize="48sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="remaining"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvTimerStateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READY"
                android:textColor="@color/blue_accent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:layout_marginTop="6dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── Controls ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btnReset"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="↺"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_secondary"
            android:layout_marginEnd="18dp"
            android:stateListAnimator="@null"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnStartFocus"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="▶"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_primary"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnPause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="⏸"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_primary"
            android:stateListAnimator="@null"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnResume"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="▶"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_primary"
            android:stateListAnimator="@null"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnStartBreak"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="☕"
            android:textSize="20sp"
            android:textColor="@color/text_secondary"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_secondary"
            android:layout_marginStart="18dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- ── Task selector card ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="16dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENTLY WORKING ON"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLinkedTask"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No task linked"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Spinner
            android:id="@+id/spinnerTaskSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:popupBackground="@color/bg_mid" />
    </LinearLayout>
</LinearLayout>