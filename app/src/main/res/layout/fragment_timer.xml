<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent">

    <!-- ── Header ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focus Timer"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Set by TimerViewModel → sessionCount value -->
            <TextView
                android:id="@+id/tvSessionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sessions today: 0"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Session progress dots (visual only — 4 dots for Pomodoro cycle) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_session_dot_empty"
                android:layout_marginEnd="6dp" />
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_session_dot_empty"
                android:layout_marginEnd="6dp" />
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_session_dot_active"
                android:layout_marginEnd="6dp" />
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_session_dot_empty" />
        </LinearLayout>

    </LinearLayout>

    <!-- ── Big ring countdown ────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="18dp">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_timer_ring" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Set by TimerViewModel → DateTimeUtils.formatCountdown(millis) -->
            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25:00"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="remaining"
                android:textColor="#94A3B8"
                android:textSize="13sp" />

            <!-- Set by TimerViewModel → currentLabel (FOCUS / BREAK / PAUSED / Ready) -->
            <TextView
                android:id="@+id/tvTimerStateLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READY"
                android:textColor="#93C5FD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── Controls ──────────────────────────────────────────────────────── -->
    <!-- Visibility of each button controlled by TimerFragment.updateButtonVisibility() -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="18dp">

        <!-- Visible in: FOCUS, SHORT_BREAK, LONG_BREAK, PAUSED -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="↺"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_secondary"
            android:layout_marginEnd="16dp"
            android:visibility="gone" />

        <!-- Visible in: IDLE -->
        <Button
            android:id="@+id/btnStartFocus"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:text="▶"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:padding="17dp"
            android:background="@drawable/bg_ctrl_primary" />

        <!-- Visible in: FOCUS, SHORT_BREAK, LONG_BREAK -->
        <Button
            android:id="@+id/btnPause"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:text="⏸"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_primary"
            android:visibility="gone" />

        <!-- Visible in: PAUSED -->
        <Button
            android:id="@+id/btnResume"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:text="▶"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:padding="0dp"
            android:background="@drawable/bg_ctrl_primary"
            android:visibility="gone" />

        <!-- Visible in: IDLE -->
        <Button
            android:id="@+id/btnStartBreak"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="☕"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:padding="10dp"
            android:background="@drawable/bg_ctrl_secondary"
            android:layout_marginStart="16dp" />

    </LinearLayout>

    <!-- ── Task selector card ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="14dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CURRENTLY WORKING ON"
            android:textColor="#94A3B8"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <!-- Set by TimerFragment spinner selection → timerViewModel.setLinkedTask() -->
        <TextView
            android:id="@+id/tvLinkedTask"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No task linked"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Populated by TasksViewModel.getIncompleteTasks() in TimerFragment -->
        <Spinner
            android:id="@+id/spinnerTaskSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"
            android:popupBackground="#1B3A6B" />

    </LinearLayout>

</LinearLayout>
